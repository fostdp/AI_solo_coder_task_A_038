# ============================================
# 数据库配置
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=freeze_dryer_db
DB_HOST=timescaledb
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password_here@timescaledb:5432/freeze_dryer_db
DATABASE_SYNC_URL=postgresql://postgres:your_secure_password_here@timescaledb:5432/freeze_dryer_db

# ============================================
# Redis配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# MQTT Broker配置
# ============================================
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_WS_PORT=8083
MQTT_USERNAME=admin
MQTT_PASSWORD=public
MQTT_TOPIC=mes/alarm
MQTT_CLIENT_ID=freeze_dryer_system
MQTT_TLS_ENABLED=false

# ============================================
# Profinet模拟器配置
# ============================================
SIM_NUM_DEVICES=10
SIM_NUM_SHELVES=5
SIM_TEMP_SENSORS_PER_SHELF=8
SIM_VACUUM_SENSORS_PER_SHELF=2
SIM_REPORT_INTERVAL=10
SIM_ENABLE_ANOMALY=true
SIM_ANOMALY_INTERVAL=120
PROFINET_SIMULATOR_PORT=8001

# ============================================
# API网关配置
# ============================================
HTTP_PORT=8000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
VITE_API_BASE_URL=/api
VITE_API_URL=http://localhost:8000

# ============================================
# 微服务配置
# ============================================
CONTROL_INTERVAL=10
PREDICTION_INTERVAL=60
ALARM_CHECK_INTERVAL=10
ALARM_COOLDOWN=30
DB_BATCH_SIZE=50
DB_FLUSH_INTERVAL=10

# 阈值配置
TEMPERATURE_DIFF_THRESHOLD=1.0
VACUUM_MIN=0.0001
VACUUM_MAX=0.1
COLD_TRAP_MAX=-50.0
MOISTURE_MAX=3.0
RECONSTITUTION_MAX=5.0

# ============================================
# 前端配置
# ============================================
VITE_APP_TITLE=生物制药冻干机监控系统
API_BASE_URL=/api

# ============================================
# 监控和日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
TRACING_ENDPOINT=http://jaeger:4317
